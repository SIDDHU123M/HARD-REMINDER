<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Spacer to push content towards center-top -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ImageView
        android:layout_width="108dp"
        android:layout_height="108dp"
        android:layout_marginBottom="28dp"
        android:src="@drawable/ic_alarm_large"
        android:contentDescription="Alarm ringing"
        android:importantForAccessibility="yes" />

    <TextView
        android:id="@+id/textAlarmTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reminder"
        android:textColor="@color/text_on_primary"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="12dp"
        android:maxLines="3"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/textAlarmMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Time's up!"
        android:textColor="@color/text_on_primary_muted"
        android:textSize="18sp"
        android:textAlignment="center"
        android:maxLines="4"
        android:ellipsize="end" />

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDismiss"
        android:layout_width="240dp"
        android:layout_height="64dp"
        android:text="DISMISS"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="@color/surface"
        android:textColor="@color/primary"
        android:contentDescription="Dismiss this alarm"
        app:cornerRadius="32dp"
        app:elevation="6dp" />

    <View
        android:layout_width="0dp"
        android:layout_height="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSnooze"
        android:layout_width="240dp"
        android:layout_height="52dp"
        android:text="SNOOZE"
        android:textSize="15sp"
        android:letterSpacing="0.08"
        android:contentDescription="Snooze this alarm"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@color/text_on_primary"
        app:strokeColor="@color/text_on_primary"
        app:strokeWidth="1.5dp"
        app:cornerRadius="26dp" />

    <View
        android:layout_width="0dp"
        android:layout_height="32dp" />

</LinearLayout>
